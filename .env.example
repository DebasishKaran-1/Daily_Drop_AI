PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/dailydrop
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7
GNEWS_API_KEY=replace-with-gnews-key
GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=replace-with-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5001/auth/google/callback
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=DailyDrop <no-reply@example.com>
